generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChannelRole {
  owner
  admin
  editor
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  image        String?
  createdAt    DateTime @default(now())
  renameCount  Int      @default(0)
  sessionVersion Int    @default(0)
  channels       Channel[]       @relation("ChannelOwner")
  editors        ChannelEditor[]
  media          Media[]
  pendingUploads PendingUpload[]
}

model Channel {
  id              String   @id @default(cuid())
  avatarUrl       String?
  isPersonal      Boolean  @default(false)
  renameCount     Int      @default(0)
  defaultLanguage String   @default("en")
  createdAt       DateTime @default(now())
  ownerId         String
  owner    User              @relation("ChannelOwner", fields: [ownerId], references: [id])
  posts    Post[]
  editors  ChannelEditor[]
  slugHistory     ChannelSlugHistory[]
  translations    ChannelTranslation[]

  @@index([ownerId, isPersonal])
  @@index([createdAt, id])
}

model ChannelTranslation {
  id             String   @id @default(cuid())
  channelId      String
  language       String
  name           String
  normalizedName String   @default("") @unique
  slug           String   @unique
  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, language])
  @@index([language])
  @@index([channelId])
}

model ChannelSlugHistory {
  id                String   @id @default(cuid())
  oldSlug           String   @unique
  oldNormalizedName String
  channelId         String
  channel           Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@index([channelId])
  @@index([oldNormalizedName])
}

model ChannelEditor {
  channelId String
  channel   Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ChannelRole  @default(editor)

  @@id([channelId, userId])
}

model Post {
  id        String   @id @default(cuid())
  content   String?
  isPublic  Boolean  @default(true)
  language  String   @default("en")
  createdAt DateTime @default(now())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  media     Media[]

  @@index([channelId])
  @@index([isPublic, createdAt])
  @@index([language, isPublic, createdAt])
  @@index([createdAt, id])
}

model RateLimit {
  key       String   @id
  count     Int
  expiresAt DateTime

  @@index([expiresAt])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   // "image" | "video" | "youtube" | "file"
  position  Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}

model PendingUpload {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  channelId String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([userId])
}
