generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChannelRole {
  owner
  editor
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  image     String?
  createdAt DateTime @default(now())
  channels  Channel[]       @relation("ChannelOwner")
  editors   ChannelEditor[]
  media     Media[]
}

model Channel {
  id             String   @id @default(cuid())
  name           String   @unique
  normalizedName String   @default("")
  slug           String   @unique
  avatarUrl      String?
  createdAt      DateTime @default(now())
  ownerId        String
  owner     User          @relation("ChannelOwner", fields: [ownerId], references: [id])
  posts     Post[]
  editors   ChannelEditor[]

  @@index([ownerId])
}

model ChannelEditor {
  channelId String
  channel   Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ChannelRole  @default(editor)

  @@id([channelId, userId])
}

model Post {
  id        String   @id @default(cuid())
  content   String?
  isPublic  Boolean  @default(true)
  language  String   @default("en")
  createdAt DateTime @default(now())
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  media     Media[]

  @@index([channelId])
  @@index([isPublic, createdAt])
  @@index([language, isPublic, createdAt])
}

model RateLimit {
  key       String   @id
  count     Int
  expiresAt DateTime

  @@index([expiresAt])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   // "image" | "video" | "youtube" | "file"
  position  Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
}
