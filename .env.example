# 🪷 Sincere Bhakti — Environment Variables

# --- Database ---
# Development (local PostgreSQL):
DATABASE_URL="postgresql://postgres:postgres@localhost:5431/sincerebhakti"
# Production (Neon — set in Vercel dashboard):
# DATABASE_URL="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/sincerebhakti?sslmode=require"

# --- NextAuth ---
NEXTAUTH_SECRET="<generate-a-random-string>"
NEXTAUTH_URL="http://localhost:3000"
# Vercel: set NEXTAUTH_URL to your deployment URL, e.g. "https://www.sincerebhakti.com"
