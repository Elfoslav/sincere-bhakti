# 🪷 Sincere Bhakti — Environment Variables
# Copy this file to .env for local dev.

# --- Database ---
# Local SQLite:
DATABASE_URL="file:./dev.db"
# Turso (Vercel — set these in Vercel dashboard):
# DATABASE_URL="libsql://sincere-bhakti-dev-elfoslav.turso.io"
# TURSO_AUTH_TOKEN="<your-turso-token>"

# --- NextAuth ---
NEXTAUTH_SECRET="<generate-a-random-string>"
# Vercel: set NEXTAUTH_URL to your deployment URL, e.g. "https://sincere-bhakti.vercel.app"
