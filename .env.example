# 🪷 Sincere Bhakti — Environment Variables

# --- Database ---
# Development (local PostgreSQL):
DATABASE_URL="postgresql://postgres:postgres@localhost:5431/sincerebhakti"
# Database for tests
TEST_DATABASE_URL = "postgresql://elfoslav@localhost:5431/sincerebhakti_test"
# Production (Neon — set in Vercel dashboard, use verify-full for security):
# DATABASE_URL="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/sincerebhakti?sslmode=verify-full"

# Default account
SINCERE_BHAKTI_NAME="<your-name>"
SINCERE_BHAKTI_EMAIL="<your-email>"
SINCERE_BHAKTI_PASSWORD="<your-password>"

# --- NextAuth ---
NEXTAUTH_SECRET="<generate-a-random-string>"
NEXTAUTH_URL="http://localhost:3000"
# Vercel: set NEXTAUTH_URL to your deployment URL, e.g. "https://www.sincerebhakti.com"

# Rate limiting uses your PostgreSQL database in production (via Prisma).
# In-memory fallback used in local dev/test — no extra setup needed.

# Sentry
NEXT_PUBLIC_SENTRY_DSN="<your-sentry-dsn>" # Client SENTRY_DSN
SENTRY_DSN="<your-sentry-dsn>" # Server SENTRY_DSN
SENTRY_AUTH_TOKEN="<your-sentry-auth-token>"

# --- Cloudflare R2 (file uploads) ---
# Create R2 bucket and generate API token in Cloudflare Dashboard:
# R2 > Overview > Create bucket > "sincere-bhakti-uploads"
# R2 > Manage R2 API Tokens > Create API Token (read+write)
# Then set the public URL: R2 > bucket > Settings > Public Access
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="<your-access-key>"
R2_SECRET_ACCESS_KEY="<your-secret-key>"
R2_BUCKET="sincere-bhakti-uploads"
R2_PUBLIC_URL="https://pub-<hash>.r2.dev"